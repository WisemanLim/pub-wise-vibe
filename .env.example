# .env.example - Vibe Coding Environment (MacOS/Seoul)
# 2026-02 기준: 각 서비스별 비용 최적 / 성능 최적 모델 중 하나를 선택해 사용
# Copy to .env and fill values. source .env before running setup_vibe

### [Gemini CLI Block]
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
# 2026-02 기준 모델 선택 (아래 중 하나만 사용)
# 비용 최적: Flash 계열 (저렴, 빠름) — ai.google.dev/gemini-api/docs/pricing
GEMINI_MODEL=gemini-2.5-flash
# 성능 최적: Pro 계열 (고품질, 긴 컨텍스트)
# GEMINI_MODEL=gemini-2.5-pro
# GEMINI_MODEL=gemini-3-pro-preview
# 추가: PROXY=... (회사 네트워크 시)

### [Claude Code Block]
# Anthropic Console: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here
# 2026-02 기준 모델 선택 (아래 중 하나만 사용)
# 비용 최적: Haiku 4.5 ($1 in / $5 out per 1M tokens)
CLAUDE_MODEL=claude-haiku-4.5
# 성능 최적: Opus 4.5 ($5 in / $25 out per 1M tokens)
# CLAUDE_MODEL=claude-opus-4.5
# 추가: MAX_TOKENS=4096

### [Continue + Ollama Block] (로컬, API 비용 없음)
OLLAMA_BASE_URL=http://localhost:11434
# 2026-02 기준 모델 선택 (아래 중 하나만 사용)
# 비용(리소스) 최적: 소형 모델, 적은 VRAM/RAM
OLLAMA_MODEL=deepseek-coder:6.7b-q4_K_M
# 성능 최적: 대형 모델 (24GB+ VRAM 또는 32GB+ RAM 권장)
# OLLAMA_MODEL=qwen2.5-coder:32b
# OLLAMA_MODEL=deepseek-coder:33b-instruct-q4_K_M
# 추가: OLLAMA_GPU_LAYERS=35 (M2 Max+), NUM_CTX=8192

### [Cursor Block]
# Cursor Settings > API 에서 백엔드 연결 후 모델 선택
CURSOR_API_KEY=your_openai_or_gemini_key_here
# 2026-02 기준 모델 선택 (Cursor Pro/Pro+ 요금제 내 사용량 소진)
# 비용 최적: Gemini 3 / Sonnet
CURSOR_PRIMARY_MODEL=gemini-3-flash
# 성능 최적: Claude Opus 4.6 / GPT-4o / Gemini 3 Pro
# CURSOR_PRIMARY_MODEL=claude-opus-4.6
# 추가: RULES_PATH=~/.cursor/rules/bio.md

### [Cline Block]
# VSCode Extension: cline-ai.cline | Settings > API Key
CLINE_PROVIDER=openai
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
# 2026-02 기준 모델 선택 (provider별로 해당 API 모델명 사용)
# 비용 최적 (OpenAI): gpt-4o-mini | (Anthropic): claude-haiku-4.5
# 성능 최적 (OpenAI): gpt-4o | (Anthropic): claude-opus-4.5
# 추가: CLINE_MAX_TOKENS=8000

# 공통
NODE_VERSION=22.x
VS_CODE_PATH="/Applications/Visual Studio Code.app"
# 사용: cp .env.example .env; 원하는 모델만 주석 해제 후 source .env; setup_vibe
